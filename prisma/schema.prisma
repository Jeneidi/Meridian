// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model User {
  id                   String    @id @default(cuid())
  name                 String?
  email                String?   @unique
  emailVerified        DateTime?
  image                String?
  githubId             String?   @unique
  plan                 Plan      @default(FREE)
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  createdAt            DateTime  @default(now())

  accounts         Account[]
  sessions         Session[]
  repos            Repo[]
  checkIns         CheckIn[]
  sentInvites      TeamInvite[]   @relation("SentInvites")
  receivedInvites  TeamInvite[]   @relation("ReceivedInvites")
  notifications    Notification[]
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Repo {
  id            String    @id @default(cuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  githubRepoId  Int       @unique
  name          String
  fullName      String
  url           String
  defaultBranch String    @default("main")
  connectedAt   DateTime  @default(now())
  roadmapGenAt  DateTime?
  tasks         Task[]
  checkIns      CheckIn[]
  dailyTasks    DailyTask[]
  invites       TeamInvite[]

  @@index([userId])
}

model Task {
  id            String      @id @default(cuid())
  repoId        String
  repo          Repo        @relation(fields: [repoId], references: [id], onDelete: Cascade)
  title         String
  description   String
  estimate      Int         // minutes: 30 or 60
  difficulty    Int         // 1-5
  priority      Int         // 1-10
  status        TaskStatus  @default(TODO)
  files         String      @default("[]") // JSON array of file paths
  microSteps    String      @default("[]") // JSON array of 3-5 steps
  isOptional    Boolean     @default(false) // true = enhancement, false = core
  category      String      @default("feature") // "feature" | "bug" | "improvement"
  createdAt     DateTime    @default(now())
  completedAt   DateTime?
  history       TaskHistory[]
  dailyTasks    DailyTask[]

  @@index([repoId])
  @@index([status])
}

model CheckIn {
  id            String    @id @default(cuid())
  repoId        String
  repo          Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  summary       String
  diffSnippet   String?
  aiCoaching    String
  createdAt     DateTime  @default(now())

  @@index([repoId])
  @@index([userId])
  @@index([createdAt])
}

model TaskHistory {
  id            String    @id @default(cuid())
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedAt   DateTime  @default(now())
  sessionNotes  String?

  @@index([taskId])
}

model DailyTask {
  id            String    @id @default(cuid())
  repoId        String
  repo          Repo      @relation(fields: [repoId], references: [id], onDelete: Cascade)
  taskId        String
  task          Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  date          DateTime  @default(now())
  reasoning     String

  @@unique([repoId, date])
  @@index([date])
}

enum TaskStatus {
  TODO
  IN_PROGRESS
  DONE
  SKIPPED
}

enum Plan {
  FREE
  PRO
  PREMIUM
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
}

model TeamInvite {
  id          String       @id @default(cuid())
  repoId      String
  repo        Repo         @relation(fields: [repoId], references: [id], onDelete: Cascade)
  inviterId   String
  inviter     User         @relation("SentInvites", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId   String
  invitee     User         @relation("ReceivedInvites", fields: [inviteeId], references: [id], onDelete: Cascade)
  status      InviteStatus @default(PENDING)
  createdAt   DateTime     @default(now())
  respondedAt DateTime?

  @@unique([repoId, inviteeId])
  @@index([inviteeId, status])
  @@index([inviterId])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  inviteId  String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([userId, read])
}
